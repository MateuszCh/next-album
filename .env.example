# App API credentials from https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_SHARED_SECRET=your_lastfm_shared_secret

# Base app URL (used to build the callback URL during login).
# Locally usually http://localhost:3000
APP_URL=http://localhost:3000

# Secret used to encrypt the session cookie (iron-session). Minimum 32 chars.
# Generate e.g. with: openssl rand -base64 32
SESSION_SECRET=change_me_to_a_long_random_string_min_32_chars

# --- Access control (optional) ---

# Shared password gate in front of the whole app. Empty = gate disabled (open).
# When set, must be at least 8 characters.
ACCESS_PASSWORD=

# Allowlist of Last.fm usernames (comma-separated), e.g. mateusz,ania
# Empty = every logged-in user has access (allowlist disabled).
ALLOWED_LASTFM_USERS=
